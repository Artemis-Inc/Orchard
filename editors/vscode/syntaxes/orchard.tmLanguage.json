{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Orchard",
  "scopeName": "source.orchard",
  "patterns": [
    { "include": "#pragma" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "pragma": {
      "match": "^#!orchard\\b.*$",
      "name": "comment.line.pragma.orchard"
    },
    "comments": {
      "patterns": [
        { "match": "//.*$", "name": "comment.line.double-slash.orchard" },
        {
          "begin": "/\\*",
          "end": "\\*/",
          "name": "comment.block.orchard"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "name": "string.quoted.triple.orchard",
          "patterns": [{ "include": "#interpolation" }]
        },
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.orchard",
          "patterns": [
            { "match": "\\\\([ntr\"\\\\{}]|u\\{[0-9A-Fa-f]+\\})", "name": "constant.character.escape.orchard" },
            { "include": "#interpolation" }
          ]
        },
        {
          "begin": "`",
          "end": "`",
          "name": "string.quoted.raw.orchard"
        }
      ]
    },
    "interpolation": {
      "begin": "\\{",
      "end": "\\}",
      "name": "meta.interpolation.orchard",
      "patterns": [
        { "include": "#keywords" },
        { "include": "#constants" },
        { "include": "#numbers" },
        { "include": "#strings" }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(agent|skill|type|enum|tool)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.orchard" },
            "2": { "name": "entity.name.type.orchard" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(on|return|let|match|gen|as|spawn|await|parallel|delegate|model|import|use|if|else|for|while|in|until|catch|try)\\b",
          "name": "keyword.control.orchard"
        }
      ]
    },
    "constants": {
      "match": "\\b(true|false|null)\\b",
      "name": "constant.language.orchard"
    },
    "types": {
      "match": "\\b(str|int|float|bool|duration|money|list|map|any)\\b",
      "name": "support.type.orchard"
    },
    "numbers": {
      "patterns": [
        { "match": "\\$[0-9][0-9_]*(\\.[0-9]+)?", "name": "constant.numeric.money.orchard" },
        { "match": "\\b[0-9][0-9_]*(\\.[0-9]+)?([eE][+-]?[0-9]+)?\\b", "name": "constant.numeric.orchard" },
        { "match": "\\b[0-9]+(s|m|h|d)\\b", "name": "constant.numeric.duration.orchard" }
      ]
    },
    "operators": {
      "match": "(\\|>|\\?\\?|->|=>|==|!=|<=|>=|&&|\\|\\||[+\\-*/%<>=!?:])",
      "name": "keyword.operator.orchard"
    }
  }
}
